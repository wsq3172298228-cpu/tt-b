{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/bin/memory-reminder.js",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node .claude/bin/memory-compress.js",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/bin/memory-reminder.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
